{
  "name": "impostor-web",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace shared && npm run build --workspace server && npm run build --workspace client",
    "test": "npm run test --workspace server",
    "sim:pilot": "npm run sim:pilot --workspace server --",
    "sim:pilot:chaos": "npm run sim:pilot --workspace server -- --chaos --players 10 --matches 100 --disconnect-rate 0.4",
    "test:smoke": "playwright test --config e2e/playwright.config.ts",
    "test:smoke:headed": "playwright test --config e2e/playwright.config.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}

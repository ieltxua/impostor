{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@impostor/shared": ["../shared/src/index.ts"],
      "@impostor/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
